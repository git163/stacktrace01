{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake -S . -B build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$cmake"],
            "group": "build"
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake --build build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": ["CMake: Configure"],
            "problemMatcher": ["$cmake"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake --build build --clean-first",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Hello World",
            "type": "shell",
            "command": "${workspaceFolder}/build/bin/hello",
            "dependsOn": ["CMake: Build"],
            "problemMatcher": []
        }
    ]
}